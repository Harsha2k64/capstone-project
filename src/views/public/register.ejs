<!DOCTYPE html>
<html lang="en">
<%- include('../templates/head.ejs') -%>

<body class="bg-primary">
    <%- include('../templates/header.ejs') -%>
    <div class="container mt-5">
        <div class="row">
            <div class="col"></div>
            <div class="col-5 text-white">
                <h1>Registration</h1>

                <!-- Step 1: Registration Form -->
                <div id="step-register">
                    <div class="form-group">
                        <label>Full Name</label>
                        <input type="text" class="form-control" id="reg-name">
                    </div>
                    <div class="form-group">
                        <label>Email address</label>
                        <input type="email" class="form-control" id="reg-email">
                        <small class="form-text text-muted">We'll never share your email with anyone else.</small>
                    </div>
                    <div class="form-group">
                        <label>Password</label>
                        <input type="password" class="form-control" id="reg-password">
                    </div>
                    <div id="reg-error" class="badge badge-danger my-2 d-none"></div>
                    <button class="btn btn-warning float-right" onclick="handleSendOTP()">Send OTP</button>
                </div>

                <!-- Step 2: OTP Verification -->
                <div id="step-otp" class="d-none">
                    <p class="text-muted">An OTP has been sent to <strong id="otp-email-display"></strong></p>

                    <div class="form-group">
                        <label>Enter OTP</label>
                        <input type="text" class="form-control" id="otp-input" maxlength="6" placeholder="6-digit OTP">
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span id="timer-display" class="text-warning font-weight-bold"></span>
                        <button class="btn btn-link text-warning p-0 d-none" id="resend-btn" onclick="handleResendOTP()">Send again</button>
                    </div>

                    <div id="otp-error" class="badge badge-danger my-2 d-none"></div>
                    <div id="otp-success" class="badge badge-success my-2 d-none"></div>

                    <button class="btn btn-warning float-right" onclick="handleVerifyOTP()">Verify OTP</button>
                </div>

                <!-- Step 3: Hidden form submitted after OTP verified -->
                <div id="step-submit" class="d-none">
                    <form method="POST" action="/login/register" id="final-form">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="hidden" name="name" id="hidden-name">
                        <input type="hidden" name="username" id="hidden-email">
                        <input type="hidden" name="password" id="hidden-password">
                    </form>
                </div>

            </div>
            <div class="col"></div>
        </div>
    </div>

    <script>
        let timerInterval = null;

        function showError(elementId, message) {
            const el = document.getElementById(elementId);
            el.textContent = message;
            el.classList.remove('d-none');
        }

        function hideError(elementId) {
            document.getElementById(elementId).classList.add('d-none');
        }

        function startTimer(seconds) {
            clearInterval(timerInterval);
            const display = document.getElementById('timer-display');
            const resendBtn = document.getElementById('resend-btn');
            resendBtn.classList.add('d-none');

            let remaining = seconds;

            function tick() {
                const m = Math.floor(remaining / 60).toString().padStart(2, '0');
                const s = (remaining % 60).toString().padStart(2, '0');
                display.textContent = `Resend OTP in ${m}:${s}`;
                if (remaining <= 0) {
                    clearInterval(timerInterval);
                    display.textContent = '';
                    resendBtn.classList.remove('d-none');
                }
                remaining--;
            }

            tick();
            timerInterval = setInterval(tick, 1000);
        }

        async function handleSendOTP() {
            hideError('reg-error');
            const name = document.getElementById('reg-name').value.trim();
            const email = document.getElementById('reg-email').value.trim();
            const password = document.getElementById('reg-password').value;

            if (!name || !email || !password) {
                return showError('reg-error', 'Please fill in all fields.');
            }

            document.getElementById('hidden-name').value = name;
            document.getElementById('hidden-email').value = email;
            document.getElementById('hidden-password').value = password;
            document.getElementById('otp-email-display').textContent = email;

            try {
                const resp = await fetch('/ajax/sendOTP', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });
                const data = await resp.json();

                if (data.success) {
                    document.getElementById('step-register').classList.add('d-none');
                    document.getElementById('step-otp').classList.remove('d-none');
                    startTimer(120);
                } else {
                    showError('reg-error', data.message);
                }
            } catch (e) {
                showError('reg-error', 'Network error. Please try again.');
            }
        }

        async function handleResendOTP() {
            const email = document.getElementById('hidden-email').value;
            hideError('otp-error');
            document.getElementById('otp-input').value = '';

            try {
                const resp = await fetch('/ajax/sendOTP', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });
                const data = await resp.json();

                if (data.success) {
                    // New OTP sent — old one already overwritten on server
                    startTimer(120);
                } else {
                    showError('otp-error', data.message);
                }
            } catch (e) {
                showError('otp-error', 'Network error. Please try again.');
            }
        }

        async function handleVerifyOTP() {
            hideError('otp-error');
            const otp = document.getElementById('otp-input').value.trim();
            const email = document.getElementById('hidden-email').value;

            if (!otp) {
                return showError('otp-error', 'Please enter the OTP.');
            }

            try {
                const resp = await fetch('/ajax/verifyOTP', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ otp, email })
                });
                const data = await resp.json();

                if (data.success) {
                    clearInterval(timerInterval);
                    const successEl = document.getElementById('otp-success');
                    successEl.textContent = 'OTP verified! Registering...';
                    successEl.classList.remove('d-none');

                    setTimeout(() => {
                        document.getElementById('final-form').submit();
                    }, 800);
                } else {
                    showError('otp-error', data.message);
                }
            } catch (e) {
                showError('otp-error', 'Network error. Please try again.');
            }
        }
    </script>

</body>
</html>